{
  "private": true,
  "packageManager": "pnpm@10.34.3",
  "workspaces": [
    "packages/*",
    "packages/svg2font-cli/npm/*"
  ],
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "format": "oxfmt packages/svg2font/src packages/svg2font-cli/src",
    "format:check": "oxfmt --check packages/svg2font/src packages/svg2font-cli/src",
    "lint": "oxlint packages/svg2font/src packages/svg2font-cli/src",
    "lint:fix": "oxlint --fix packages/svg2font/src packages/svg2font-cli/src"
  },
  "devDependencies": {
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0"
  }
}
